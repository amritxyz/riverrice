# zathurarc
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
map g goto top
map a adjust_window best-fit
map B toggle_statusbar
map M toggle_page_mode
map C toggle_inputbar
map [fullscreen] u scroll half-up
map [fullscreen] d scroll half-down
map [fullscreen] D toggle_page_mode
map [fullscreen] r reload
map [fullscreen] R rotate
map [fullscreen] K zoom in
map [fullscreen] J zoom out
map [fullscreen] i recolor
map [fullscreen] p print
map [fullscreen] g goto top
map [fullscreen] a adjust_window best-fit
map [fullscreen] B toggle_statusbar

# set sandbox none
set font "cozette 10"
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
set guioptions none
set statusbar-home-tilde true
set zoom-step 5

set notification-error-bg "#ff8f88"
set notification-error-fg "#000000"
set notification-warning-bg "#f3d000"
set notification-warning-fg "#000000"
set notification-bg "#ffffff"
set notification-fg "#000000"
set completion-bg "#ffffff"
set completion-fg "#595959"
set completion-group-bg "#ffffff"
set completion-group-fg "#595959"
set completion-highlight-bg "#006800"
set completion-highlight-fg "#ffffff"
set index-bg "#ffffff"
set index-fg "#000000"
set index-active-bg "#0031a9"
set index-active-fg "#ffffff"
set inputbar-bg "#ffffff"
set inputbar-fg "#000000"
set statusbar-bg "#c8c8c8"
set statusbar-fg "#0a0a0a"
set highlight-color "#6f5500"
set highlight-active-color "#006800"
set default-bg "#ffffff"
set default-fg "#000000"
set render-loading true
set render-loading-fg "#ffffff"
set render-loading-bg "#000000"

set recolor-lightcolor "#ffffff"
set recolor-darkcolor "#000000"
