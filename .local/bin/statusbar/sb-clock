#!/bin/sh

case $BLOCK_BUTTON in
	3) notify-send "This Month" "$(cal | sed "s/\<$(date +'%e'|tr -d ' ')\>/<b><span color='red'>&<\/span><\/b>/")" \
		&& notify-send "Appointments" "$(calcurse -d3)" ;;
	2) pkill calcurse || setsid -f "$TERMINAL" -t fterm -e calcurse ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# Output time and date in a clean format
printf "%s %s %s\n" "$(date '+%a, %B %d')" "|" "$(date '+%I:%M %p')"
