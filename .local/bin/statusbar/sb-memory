#!/bin/sh

case "$BLOCK_BUTTON" in
	3) notify-send "Memory Hogs" "$( ps axch -o cmd=,%mem= \
			| awk '{gsub(/[:\/].*/, "", $1); cmd[$1]+=$2} END {for (i in cmd) printf "%s %.1f%%\n", i, cmd[i]}' \
			| sort -nrk2 | head)" ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

free --mebi | sed -n '2{p;q}' | awk '{printf "RAM %.0f%%\n", ($3 / $2) * 100}'
