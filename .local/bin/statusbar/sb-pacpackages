#!/bin/sh

updates=$(pacman -Qu | grep -Fv "[ignored]")
count=$(printf "%s" "$updates" | wc -l)

case $BLOCK_BUTTON in
	1) kill -44 "$(pidof dwmblocks)" ;;
	3) notify-send "Upgradable packages: $count" \
	   "$(printf "%s\n" "$updates" | awk '{print $1}' | head -n 5)" ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

[ "$count" -gt 0 ] && echo "PKG: $count"
