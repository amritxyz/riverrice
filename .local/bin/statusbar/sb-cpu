#!/bin/sh
case $BLOCK_BUTTON in
	3) notify-send "CPU hogs" "$(ps axch -o cmd,%cpu \
		| awk '{
			split($1,a,"/"); split(a[1],b,":");
			cmd[b[1]] += $2
		} END {
			for (i in cmd) printf "%s %.1f%%\n", i, cmd[i]
			}' | sort -nrk2 | head)" ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

cpu_usage=$(top -bn1 | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{print 100 - $1}')
echo "CPU ${cpu_usage}%"
