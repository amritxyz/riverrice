#!/bin/sh

case $BLOCK_BUTTON in
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

for battery in /sys/class/power_supply/BAT?*; do
	status=$(cat "$battery/status" 2>/dev/null)
	capacity=$(cat "$battery/capacity" 2>/dev/null)

	case "$status" in
		Full) status=" " ;;
		Discharging) status="(-) " ;;
		Charging) status="(O) " ;;
		*) status="(?) " ;;
	esac

	output="${capacity}%$status"
	case $BLOCK_BUTTON in
		3) notify-send "Battery" "   : Full
(O): Charging
(-): Discharging
(?): Plugged in & !charging
"
	esac
done

printf "%s\n" "$output"
