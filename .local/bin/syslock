#!/bin/sh

export WM="dwl"
export WL="swaylock -c 0x000000 -L"
export CTL='systemctl'

choice=$(printf "lock\nsleep\nlogout\nreboot\nshutdown" | \
	fuzzel -p 'Action: ' -I -l 5 --no-mouse --dmenu \
	--match-mode=exact --no-sort
)

case "$choice" in
	'lock') $WL ;;
	'sleep') $CTL suspend && $WL ;;
	"logout") pkill -SIGKILL $WM ;;
	'reboot') reboot ;;
	'shutdown') poweroff ;;
	*) exit 1 ;;
esac
